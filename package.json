{
  "name": "@jayf0x/npm-exists",
  "version": "2.1.0",
  "description": "The fastest way to check if an npm package exists. Zero dependencies, lightweight, and uses ultra-fast HTTP HEAD requests.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "types": "./dist/index.d.ts",
  "bin": {
    "npm-exists": "bin/npm-exists.js"
  },
  "files": [
    "dist",
    "bin",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "vite build && node scripts/generate-types.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "release": "bash publish-npm.sh",
    "prepublishOnly": "bun run build && bun run test"
  },
  "keywords": [
    "npm",
    "package",
    "exists",
    "check",
    "registry",
    "available",
    "taken",
    "name",
    "lookup",
    "cli",
    "zero-deps",
    "fetch",
    "esm",
    "typescript"
  ],
  "author": {
    "name": "Jay Fox",
    "email": "jjay56883@gmail.com"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jayF0x/npm-exists.git"
  },
  "homepage": "https://github.com/jayF0x/npm-exists#readme",
  "bugs": {
    "url": "https://github.com/jayF0x/npm-exists/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "vite": "^6.0.0",
    "vitest": "^2.0.0"
  }
}
